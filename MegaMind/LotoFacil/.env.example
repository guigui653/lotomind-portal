# ╔═══════════════════════════════════════════════════════════╗
# ║          LotoMind Enterprise — Environment               ║
# ╚═══════════════════════════════════════════════════════════╝

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=lotomind
POSTGRES_USER=lotomind
POSTGRES_PASSWORD=lotomind_secret

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-256-bit-secret-in-production

# ── Python Service ────────────────────────────────────────────
PYTHON_SERVICE_URL=http://backend-python:8000

# ── Frontend ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
